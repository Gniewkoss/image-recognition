{
  "expo": {
    "name": "FoodLens",
    "slug": "image-recognition-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6366f1"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.foodlens.app",
      "infoPlist": {
        "NSCameraUsageDescription": "This app needs camera access to take photos of your food.",
        "NSPhotoLibraryUsageDescription": "This app needs photo library access to upload food images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6366f1"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES"
      ],
      "package": "com.foodlens.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow FoodLens to access your photos.",
          "cameraPermission": "Allow FoodLens to access your camera."
        }
      ],
      "expo-asset",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "eeed460a-6909-4b1f-9893-fec22e77695a"
      }
    }
  }
}
